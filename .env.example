# -------------------------------------------------------
# Copier ce fichier en .env et remplir les valeurs réelles
# Le fichier .env ne doit PAS être versionné (voir .gitignore)
# -------------------------------------------------------

# --- Baserow ---
# URL de base de l'API Baserow
BASEROW_API_URL=xxx

# Token API Baserow (Paramètres > API tokens > Créer un token)
BASEROW_TOKEN=your_token_here

# ID de la base de données Baserow
BASEROW_DATABASE_ID=xxx

# ID de la table Invités dans la base Mariage
# Se trouve dans l'URL de la table : /database/{DATABASE_ID}/table/{TABLE_ID}
BASEROW_TABLE_ID=xxx

# --- SMTP (override optionnel de config/smtp.php) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=
# MAIL_FROM_NAME="Site Mariage"
# MAIL_TO=

# --- Dashboard (page récapitulative des RSVP) ---
# Mot de passe hachifié pour l'accès au dashboard administratif
# Générer un hash avec la commande:
#   php -r "echo password_hash('votre_mot_de_passe', PASSWORD_BCRYPT);"
# Puis coller le résultat ci-dessous entre guillemets
DASHBOARD_PASSWORD="<hash_bcrypt_ici>"
